# BlackBullChain web config. Copy to `.env` and adjust.

# Fixed RPC endpoint the whole site reads from (no in-app editing). Point it at the public
# BlackBullChain node — e.g. the Mac Mini validator exposed over Tailscale — so anyone can
# watch blocks. Local dev default:
VITE_RPC_URL=http://localhost:8899

# Faucet HTTP endpoint (dev clusters only). Leave blank to hide the airdrop button.
VITE_FAUCET_URL=

# Display name + ticker (branding only).
VITE_CHAIN_NAME=BlackBullChain
VITE_TICKER=BBC

# pump.fun page for the $BBC token (the header "$BBC" button links here).
# e.g. https://pump.fun/coin/<mint>
VITE_PUMPFUN_URL=https://pump.fun

# ---- 1:1 peg (pump.fun $BBC on Solana -> native BBC). Set these to open the peg. ----
VITE_PEG_TOKEN_MINT=          # SPL mint of $BBC on Solana
VITE_BRIDGE_TREASURY=         # Solana address users deposit $BBC into to peg
VITE_SOLANA_RPC=https://api.mainnet-beta.solana.com
