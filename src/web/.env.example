# BlackBullChain web config. Copy to `.env` and adjust.
# The Solana-compatible JSON-RPC endpoint of a BlackBullChain node.
# Local test node (blackbull-test-validator / bootstrap-validator.sh):
VITE_RPC_URL=http://localhost:8899
# Faucet HTTP endpoint used by the wallet's "airdrop" button (dev clusters only).
# Leave blank to hide the airdrop button. Node RPC also serves airdrop via requestAirdrop.
VITE_FAUCET_URL=
# Display name + ticker (branding only).
VITE_CHAIN_NAME=BlackBullChain
VITE_TICKER=BBC
# pump.fun page for the $BBC token (the header "$BBC" button links here).
# e.g. https://pump.fun/coin/<mint>
VITE_PUMPFUN_URL=https://pump.fun
